{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WukongITM",
  "version": "0.1.0",
  "identifier": "com.wukong.itm",
  "build": {
    "frontendDist": "../src",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "WukongITM",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri:; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://unpkg.com tauri:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com tauri:; font-src 'self' https://fonts.gstatic.com data:; connect-src 'self' tauri: ipc: https://unpkg.com; img-src 'self' data: tauri:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/installer.ico",
        "installMode": "perMachine"
      }
    }
  }
}
